# ─────────────────────────────────────────────────────────────
# ForexEdge — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git. Add it to .gitignore immediately.
# ─────────────────────────────────────────────────────────────

# ── SERVER ────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── DATABASE ──────────────────────────────────────────────────
# MongoDB Atlas connection string (free tier: mongodb.com/atlas)
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/forexedge

# ── AUTH ──────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=another_long_random_string_for_refresh_tokens

# ── STRIPE ────────────────────────────────────────────────────
# Get keys at: dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Price IDs (create in Stripe dashboard)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_ELITE_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_ELITE_ANNUAL=price_...

# ── TELEGRAM BOT ─────────────────────────────────────────────
# Create your bot: t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=123456789:ABCDefghIJKlmnoPQRstuvWXyz
# Your main signal channel/group ID (get with @userinfobot)
TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx
# Telegram mini app URL (once deployed)
TELEGRAM_WEBAPP_URL=https://yourapp.com

# ── FOREX DATA API ────────────────────────────────────────────
# Free tier: app.twelvedata.com/login
TWELVE_DATA_KEY=your_twelve_data_api_key
# Fallback: alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key
# Cache TTL in seconds (free tier: 30s, paid: 5s)
FOREX_CACHE_TTL=30

# ── EMAIL ─────────────────────────────────────────────────────
# Use Resend (resend.com) — generous free tier
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_your_resend_api_key
EMAIL_FROM=ForexEdge <noreply@forexedge.com>

# ── SECURITY ──────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
